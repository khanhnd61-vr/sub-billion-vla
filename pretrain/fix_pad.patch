+def resize_image_with_pad(img: torch.Tensor, width: int, height: int, pad_value: float = 0.0) -> torch.Tensor:
+    """Aspect-preserving resize of a (C, H, W) image to fit (height, width), padding top/left.
+
+    Mirrors `resize_with_pad` in the SmolVLA2 model, so resizing here (in the collate, while each
+    image is still at its native resolution) is equivalent to the resize the policy applies later.
+    Doing it here keeps the DataLoader's shared-memory footprint small on multi-resolution datasets
+    (the cause of host-RAM OOM) and avoids zero-padding small images up to a large common canvas.
+    """
+    _, cur_height, cur_width = img.shape
+    ratio = max(cur_width / width, cur_height / height)
+    resized_height = int(cur_height / ratio)
+    resized_width = int(cur_width / ratio)
+    resized = F.interpolate(
+        img.unsqueeze(0), size=(resized_height, resized_width), mode="bilinear", align_corners=False
+    ).squeeze(0)
+    pad_height = max(0, int(height - resized_height))
+    pad_width = max(0, int(width - resized_width))
+    # pad on left and top, matching the model's resize_with_pad
+    return F.pad(resized, (pad_width, 0, pad_height, 0), value=pad_value)
+
